#!/bin/bash
#
# wpall    : Activer toutes les extensions WordPress
# wpall --cancel : Annuler l’activation de toutes les extensions WordPress
# wpall --list <fichier> : Active uniquement les plugins listés dans <fichier>"
#

show_help()
{
    echo -e "${PURPLE}Utilisation :${NC} $(basename "$0") [OPTION]"
    echo ""
    echo -e "${BLUE}Description :${NC}"
    echo "  Active en masse les extensions (plugins) WordPress inactives via WP-CLI."
    echo "  Conserve une trace des plugins activés pour permettre une annulation."
    echo ""
    echo -e "${BLUE}Options :${NC}"
    echo -e "  ${GREEN}-h, --help${NC}          Affiche cette aide et quitte"
    echo -e "  ${GREEN}--list <fichier>${NC}    Active uniquement les plugins listés dans <fichier>"
    echo -e "                       (un nom de plugin par ligne)"
    echo -e "  ${GREEN}--cancel${NC}            Annule la dernière activation en masse"
    echo -e "                       (désactive les plugins listés dans previous_wpall)"
    echo ""
    echo -e "${BLUE}Sans option :${NC}"
    echo "  Active automatiquement tous les plugins actuellement inactifs."
    echo ""
    echo -e "${BLUE}Exemples :${NC}"
    echo "  $(basename "$0")"
    echo "  $(basename "$0") --list mes_plugins.txt"
    echo "  $(basename "$0") --cancel"
    echo ""
    echo -e "${BLUE}Fichiers :${NC}"
    echo "  previous_wpall   Trace des derniers plugins activés (créé/écrasé à chaque run)"
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
	show_help
	exit 0
fi

if [ "$1" = "--cancel" ]; then
	exec wpdall --list "previous_wpall"
	exit $?
fi

if [ "$1" = "--list" ] && [ -n "$2" ]; then
	extensions=$(cat "$2")
else
	extensions=$(php -d memory_limit=512M $(which wp) --allow-root plugin list --status=inactive --format=csv --field=name)
fi

if [ -z "$extensions" ]; then
    echo -e "${BLUE}[ INFO ]${NC} Pas d'extension à activer"
    exit 0
fi

if [ -e "previous_wpall" ]; then
	rm  "previous_wpall"
fi

good_display()
{
    while read -r line; do
        if [[ "$line" =~ Warning:\ (.*) ]]; then
            local detail="${BASH_REMATCH[1]}"
            echo -e "${YELLOW}[ ATTENTION ]${NC} $detail"
            continue
        fi

        if [[ "$line" =~ \'(.*)\' ]]; then
            local plugin="${BASH_REMATCH[1]}"
            echo -e "${GREEN}[ SUCCÈS ]${NC} Activation de ${PURPLE}${plugin}${NC}"
            echo $plugin >> "previous_wpall"
            continue
        fi

        if [[ "$line" =~ Error:\ (.*) ]]; then
            local detail="${BASH_REMATCH[1]}"
            echo -e "${RED}[ ERREUR ]${NC} $detail"
            continue
        fi
    done
}
php -d memory_limit=512M $(which wp) --allow-root plugin activate $extensions | good_display
echo -e "${GREEN}[ SUCCÈS ]${NC} fini !"
