#/bin/bash

source "/root/custom_cmds/includes/utils.sh"
source "/root/custom_cmds/includes/cv_source.sh"

### Aliases pour git pull de l'extension de CiviCRM et activation
## condition drupal à gérer
function cvgp() {
    instance=$(getplesksite)
    extension=$(echo "$1" | awk -F'/' '{print $NF}' | sed 's/\.git$//') # récupère ce qu'il y'a avant le .git
    testCMS

    while [ "$cms_instance" == "wordpress" ]; do 
        cd $racine/$instance/httpdocs/wp-content/uploads/civicrm/ext/$extension && git pull "$1"
        #cv en "$extension" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été mise à jour"
        break
    done

    while [ "$cms_instance" == "drupal" ]; do 
        cd $racine/$instance/httpdocs/sites/default/files/civicrm/ext/$extension && git pull "$1"
        #cv en "$extension" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été mise à jour"
        break
    done

    while [ "$cms_instance" == "standalone" ]; do 
        cd $racine/$instance/httpdocs/ext/$extension && git pull "$1"
        #cv en "$extension" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été mise à jour"
        break
    done
    rep
}

cvgp $@