# exécution parallèle contrôlée + tri final
main() {
    local racine="/var/www/vhosts"   # 🔧 adapte si ton arborescence est différente
    local max_jobs=5                 # 🔢 nombre de sites traités en parallèle
    local list_site
    mapfile -t list_site < <(plesk bin site --list)
    local tmpfile=$(mktemp)
    local running_jobs=0

    # echo "🔍 Vérification de ${#list_site[@]} sites (max $max_jobs en parallèle)..."

    for instance in "${list_site[@]}"; do
        (
            local site_path="$racine/$instance/httpdocs"

            if [[ -d "$site_path" ]]; then
                cd "$site_path" 2>/dev/null &&
                command my_timeout -t 5 cv setting:get site_id >/dev/null 2>&1 &&
                echo "$instance" >> "$tmpfile"
            fi
        ) &

        ((running_jobs++))

        # ⏳ Limite le nombre de jobs simultanés
        if (( running_jobs >= max_jobs )); then
            wait -n   # attend qu’un job se termine avant d’en lancer un autre
            ((running_jobs--))
        fi
    done

    # ⏱️ Attendre les derniers jobs
    wait

    echo
    # echo "✅ Sites valides trouvés (triés par ordre alphabétique) :"
    sort "$tmpfile"
    rm -f "$tmpfile"
}

main
