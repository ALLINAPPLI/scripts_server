#!/usr/bin/env bash
# ============================================================
# uli — User Login Instant
# Génère un lien de connexion admin pour un site WP/Drupal/Standalone
# Lance depuis n'importe quel dossier sous /var/www/vhosts/site.fr/
#
# Usage :
#   uli                      → premier admin, détection auto
#   uli -u <login|id|email>  → utilisateur précisé
# ============================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info() { echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok()   { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn() { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
die()  { echo -e "${RED}[ERROR]${RESET} $*" >&2; exit 1; }

usage() {
  echo -e "${BOLD}uli${RESET} — User Login Instant | Connexion admin WP · Drupal · Standalone"
  echo ""
  echo -e "${BOLD}Usage:${RESET}"
  echo "  uli                              premier admin, docroot détecté automatiquement"
  echo "  uli -u <login|id|email>          utilisateur précisé"
  echo ""
  echo -e "${BOLD}Lancez depuis n'importe quel dossier du site :${RESET}"
  echo "  /var/www/vhosts/site.fr/"
  echo "  /var/www/vhosts/site.fr/httpdocs"
  echo "  /var/www/vhosts/site.fr/httpdocs/wp-content/themes/montheme"
  echo ""
  echo -e "${BOLD}Exemples:${RESET}"
  echo "  uli"
  echo "  uli -u john"
  echo "  uli -u 5"
  echo "  uli -u admin@site.fr"
  exit 0
}

# ---- parsing arguments --------------------------------------
USER_ARG=""
[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

while [[ $# -gt 0 ]]; do
  case "$1" in
    --user|-user|-u)
      shift
      [[ $# -eq 0 ]] && die "Option -u attend une valeur (login, id ou email)"
      USER_ARG="$1"
      ;;
    -*)
      die "Option inconnue : $1\nUtilisez 'uli --help' pour l'aide."
      ;;
    *)
      die "Argument inattendu : $1\nuli détecte le site automatiquement depuis le dossier courant."
      ;;
  esac
  shift
done

# ============================================================
#  DÉTECTION AUTOMATIQUE vhost + docroot
# ============================================================
DOMAIN_REGEX='^[a-zA-Z0-9]([a-zA-Z0-9\-]*[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9\-]*[a-zA-Z0-9])?)+$'

find_vhost_root() {
  local dir
  dir=$(realpath "$(pwd)")
  while [[ "$dir" != "/" ]]; do
    local current parent
    current=$(basename "$dir")
    parent=$(basename "$(dirname "$dir")")
    # On est dans un sous-dossier direct d'un domaine
    if [[ "$parent" =~ $DOMAIN_REGEX ]]; then
      echo "$(dirname "$dir")"   # retourne /var/www/vhosts/site.fr
      return 0
    fi
    # On est dans le dossier domaine lui-même
    if [[ "$current" =~ $DOMAIN_REGEX ]]; then
      echo "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}

find_docroot() {
  local vhost="$1"
  # Priorité Plesk : httpdocs > public_html > www > racine vhost
  for candidate in "$vhost/httpdocs" "$vhost/public_html" "$vhost/www" "$vhost"; do
    if [[ -d "$candidate" ]] && \
       { [[ -f "$candidate/wp-config.php" ]] || \
         [[ -f "$candidate/sites/default/settings.php" ]] || \
         [[ -f "$candidate/core/lib/Drupal.php" ]] || \
         [[ -f "$candidate/index.php" ]]; }; then
      echo "$candidate"
      return 0
    fi
  done
  # Fallback : httpdocs même vide
  [[ -d "$vhost/httpdocs" ]] && echo "$vhost/httpdocs" && return 0
  echo "$vhost"
}

VHOST_ROOT=""
if ! VHOST_ROOT=$(find_vhost_root); then
  echo -e "${RED}╔══════════════════════════════════════════════════════════╗${RESET}"
  echo -e "${RED}║  ERREUR : vous n'êtes pas dans un dossier de site        ║${RESET}"
  echo -e "${RED}╚══════════════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "  Dossier courant : ${BOLD}$(pwd)${RESET}"
  echo ""
  echo -e "  ${BOLD}Positionnez-vous d'abord dans le site :${RESET}"
  echo -e "    cd /var/www/vhosts/${GREEN}monsite.fr${RESET}"
  echo -e "    cd /var/www/vhosts/${GREEN}monsite.fr${RESET}/httpdocs"
  echo ""
  exit 1
fi

SITE_DOMAIN=$(basename "$VHOST_ROOT")
DOCROOT=$(find_docroot "$VHOST_ROOT")
DOCROOT="${DOCROOT%/}"

info "Site     : ${BOLD}${SITE_DOMAIN}${RESET}"
info "Docroot  : ${BOLD}${DOCROOT}${RESET}"

# ---- détection CMS ------------------------------------------
detect_cms() {
  if [[ -f "$DOCROOT/wp-config.php" ]]; then
    echo "wordpress"
  elif [[ -f "$DOCROOT/sites/default/settings.php" ]] || \
       [[ -f "$DOCROOT/core/lib/Drupal.php" ]]; then
    echo "drupal"
  else
    echo "standalone"
  fi
}

CMS=$(detect_cms)
info "CMS      : ${BOLD}${CMS}${RESET}"

# ============================================================
#  WORDPRESS
#  Fichier one-shot → wp-content/uploads/
#  Lien             → siteurl/wp-content/uploads/uli_KEY.php?t=TOKEN
# ============================================================
wp_autologin() {
  local wp_cli

  if command -v wp &>/dev/null; then
    wp_cli="wp"
  elif [[ -f /usr/local/bin/wp ]]; then
    wp_cli="/usr/local/bin/wp"
  elif [[ -f "$DOCROOT/wp-cli.phar" ]]; then
    wp_cli="php $DOCROOT/wp-cli.phar"
  else
    die "WP-CLI introuvable. Installez-le : https://wp-cli.org"
  fi

  local WP="$wp_cli --path=$DOCROOT --allow-root"

  # URL du site depuis la base WP (source de vérité)
  local SITE_URL
  SITE_URL=$($WP option get siteurl 2>/dev/null) || die "Impossible de lire siteurl"
  SITE_URL="${SITE_URL%/}"   # enlève slash final si présent

  # Identifie l'utilisateur
  local LOGIN
  if [[ -z "$USER_ARG" ]]; then
    die "aucun parametre de passé"
  elif [[ "$USER_ARG" == 'admin' ]]; then
    LOGIN=$($WP user list --role=administrator --field=user_login --number=1 2>/dev/null | head -1)
    [[ -z "$LOGIN" ]] && die "Aucun administrateur WordPress trouvé"
    info "Premier admin    : ${BOLD}$LOGIN${RESET}"
  elif [[ "$USER_ARG" =~ ^[0-9]+$ ]]; then
    LOGIN=$($WP user get "$USER_ARG" --field=user_login 2>/dev/null) || \
      die "Utilisateur ID=$USER_ARG introuvable"
  elif [[ "$USER_ARG" == *@* ]]; then
    LOGIN=$($WP user get "$USER_ARG" --field=user_login 2>/dev/null) || \
      die "Utilisateur $USER_ARG introuvable"
  else
    LOGIN="$USER_ARG"
    $WP user get "$LOGIN" &>/dev/null || die "Utilisateur '$LOGIN' introuvable"
  fi

  # Génère le token
  local KEY TOKEN
  KEY=$(openssl rand -hex 20)
  TOKEN=$(openssl rand -hex 20)
  local EXPIRE=$(( $(date +%s) + 300 ))   # 5 minutes

  # Stocke dans les options WP
  $WP option add "uli_${KEY}" "${LOGIN}|${TOKEN}|${EXPIRE}" &>/dev/null || \
  $WP option update "uli_${KEY}" "${LOGIN}|${TOKEN}|${EXPIRE}" &>/dev/null

  # Dossier uploads (PHP exécutable ici sur Plesk, pas de restriction)
  local UPLOADS_DIR="$DOCROOT/wp-content/uploads"
  [[ -d "$UPLOADS_DIR" ]] || die "Dossier wp-content/uploads introuvable : $UPLOADS_DIR"

  local HOOK_FILE="$UPLOADS_DIR/uli_${KEY}.php"

  # wp-load.php est à la racine du docroot, soit 3 niveaux au-dessus de uploads/
  # uploads/ → wp-content/ → docroot/  donc dirname 2 fois depuis uploads
cat > "$HOOK_FILE" <<PHPEOF
<?php
// Fichier auto-généré par uli — s'auto-détruit après usage
// wp-load.php est 2 niveaux au-dessus (uploads → wp-content → docroot)
\$wp_load = dirname(__DIR__, 2) . '/wp-load.php';
if (!file_exists(\$wp_load)) { http_response_code(500); die('wp-load not found'); }
require_once \$wp_load;

\$option_key = 'uli_${KEY}';
\$stored     = get_option(\$option_key);
if (!\$stored) { http_response_code(403); die('Token expiré ou invalide'); }

list(\$login, \$token, \$expire) = explode('|', \$stored);
if ((\$_GET['t'] ?? '') !== \$token) { http_response_code(403); die('Token invalide'); }
if (time() > (int)\$expire) {
  delete_option(\$option_key);
  @unlink(__FILE__);
  http_response_code(403);
  die('Token expiré');
}

// Usage unique : supprime token et fichier
delete_option(\$option_key);
@unlink(__FILE__);

\$user = get_user_by('login', \$login);
if (!\$user) { http_response_code(404); die('Utilisateur introuvable'); }

wp_set_auth_cookie(\$user->ID, false);
wp_redirect(admin_url());
exit;
PHPEOF

  chmod 644 "$HOOK_FILE"

  # URL finale : siteurl/wp-content/uploads/uli_KEY.php?t=TOKEN
  local URL="${SITE_URL}/wp-content/uploads/uli_${KEY}.php?t=${TOKEN}"

  echo ""
  ok "Lien de connexion WP (valide ${BOLD}5 minutes${RESET}, usage unique) :"
  echo -e "\n  ${GREEN}${BOLD}${URL}${RESET}\n"
  warn "Connecte directement en tant que '${LOGIN}' — ne pas partager"
}

# ============================================================
#  DRUPAL
#  Drush génère nativement un lien one-time login — pas de fichier créé
# ============================================================
drupal_autologin() {
  local drush

  if command -v drush &>/dev/null; then
    drush="drush"
  elif [[ -f "$DOCROOT/vendor/bin/drush" ]]; then
    drush="$DOCROOT/vendor/bin/drush"
  elif [[ -f "$DOCROOT/../vendor/bin/drush" ]]; then
    drush="$DOCROOT/../vendor/bin/drush"
  else
    die "Drush introuvable. Installez-le via Composer ou https://drush.org"
  fi

  local DRUSH="$drush --root=$DOCROOT"

  local UID_ARG="1"
  if [[ -z "$USER_ARG" ]]; then
    info "Aucun utilisateur précisé → premier admin (uid=1)"
  elif [[ "$USER_ARG" =~ ^[0-9]+$ ]]; then
    UID_ARG="$USER_ARG"
  else
    UID_ARG=$($DRUSH user:information --fields=uid --format=list "$USER_ARG" 2>/dev/null | head -1) || \
      die "Utilisateur '$USER_ARG' introuvable dans Drupal"
  fi

  local URL
  URL=$($DRUSH user:login --uid="$UID_ARG" 2>/dev/null) || \
    die "Drush user:login a échoué pour uid=$UID_ARG"

  echo ""
  ok "Lien de connexion Drupal (usage unique) :"
  echo -e "\n  ${GREEN}${BOLD}${URL}${RESET}\n"
  warn "Connecte directement — ne pas partager"
}

# ============================================================
#  STANDALONE
#  Fichier one-shot → docroot/ (racine du site)
#  Lien             → https://site.fr/uli_KEY.php?t=TOKEN
# ============================================================
standalone_autologin() {
  warn "Site standalone détecté (pas de WP ni Drupal)"

  # Tentative Plesk CLI
  if command -v plesk &>/dev/null; then
    info "Plesk CLI disponible — domaine : ${BOLD}${SITE_DOMAIN}${RESET}"
    local SESSION_LINK
    SESSION_LINK=$(plesk bin admin --get-login-link 2>/dev/null || true)
    if [[ -n "$SESSION_LINK" ]]; then
      ok "Lien de connexion Plesk :"
      echo -e "\n  ${GREEN}${BOLD}${SESSION_LINK}${RESET}\n"
      return
    fi
  fi

  warn "Plesk CLI non disponible — génération d'un token PHP générique"

  [[ -f "$DOCROOT/index.php" ]] || die "Aucun index.php trouvé dans $DOCROOT"

  # Cherche l'URL dans les fichiers de config courants
  local SITE_URL=""
  for cfg in "$DOCROOT/.env" "$DOCROOT/config.php" "$DOCROOT/config/config.php" \
             "$DOCROOT/application/config/config.php"; do
    if [[ -f "$cfg" ]]; then
      SITE_URL=$(grep -iE "base_url|app_url|site_url" "$cfg" 2>/dev/null \
        | grep -oP "https?://[^'\"']+" | head -1 || true)
      [[ -n "$SITE_URL" ]] && break
    fi
  done

  # Sinon depuis la config vhost Plesk/Apache
  if [[ -z "$SITE_URL" ]]; then
    local VHOST_CONF
    VHOST_CONF=$(find /etc/apache2/conf.d /etc/nginx/conf.d /etc/apache2/vhosts.d \
                      /var/www/vhosts/system 2>/dev/null -name "*.conf" \
                | xargs grep -l "DocumentRoot.*$DOCROOT" 2>/dev/null | head -1 || true)
    if [[ -n "$VHOST_CONF" ]]; then
      SITE_URL=$(grep -oP "ServerName \K\S+" "$VHOST_CONF" 2>/dev/null | head -1 || true)
      [[ -n "$SITE_URL" ]] && SITE_URL="https://$SITE_URL"
    fi
  fi

  # Fallback : on utilise le nom de domaine détecté
  [[ -z "$SITE_URL" ]] && SITE_URL="https://${SITE_DOMAIN}"
  SITE_URL="${SITE_URL%/}"
  info "URL : ${BOLD}${SITE_URL}${RESET}"

  local KEY TOKEN
  KEY=$(openssl rand -hex 16)
  TOKEN=$(openssl rand -hex 16)
  local EXPIRE=$(( $(date +%s) + 300 ))
  local HOOK="$DOCROOT/uli_${KEY}.php"

cat > "$HOOK" <<PHPEOF
<?php
// Fichier auto-généré par uli — s'auto-détruit après usage
\$token  = '${TOKEN}';
\$expire = ${EXPIRE};
\$user   = '${USER_ARG:-admin}';

if ((\$_GET['t'] ?? '') !== \$token) { http_response_code(403); @unlink(__FILE__); die('Token invalide'); }
if (time() > \$expire)               { http_response_code(403); @unlink(__FILE__); die('Token expiré');   }

@unlink(__FILE__);
session_start();
\$_SESSION['autologin_user'] = \$user;
\$_SESSION['autologin_time'] = time();
// Adaptez la redirection à votre application :
header('Location: ' . '${SITE_URL}/admin');
exit;
PHPEOF

  chmod 644 "$HOOK"
  echo ""
  ok "Lien de connexion standalone (valide ${BOLD}5 min${RESET}, usage unique) :"
  echo -e "\n  ${GREEN}${BOLD}${SITE_URL}/uli_${KEY}.php?t=${TOKEN}${RESET}\n"
  warn "Adaptez la redirection dans le PHP si votre admin n'est pas sur /admin"
}

# ============================================================
#  DISPATCH
# ============================================================
case "$CMS" in
  wordpress)  wp_autologin ;;
  drupal)     drupal_autologin ;;
  standalone) standalone_autologin ;;
esac
