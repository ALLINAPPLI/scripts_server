#!/bin/bash

show_help()
{
    cat <<EOF
Usage: $(basename "$0") [OPTION]

Désactive en masse les plugins WordPress actifs via WP-CLI.

Options :
  (aucune)              Désactive tous les plugins actuellement actifs
  --list <fichier>      Désactive uniquement les plugins listés dans <fichier>
                         (un nom de plugin par ligne)
  --cancel               Réactive les plugins désactivés lors du dernier passage
                         (utilise le fichier "previous_wpdall")
  -h, --helper          Affiche cette aide et quitte

Fichiers :
  previous_wpdall        Contient la liste des plugins désactivés avec succès
                         lors de la dernière exécution. Recréé à chaque run.

Exemples :
  $(basename "$0")
  $(basename "$0") --list mes_plugins.txt
  $(basename "$0") --cancel
EOF
}

if [ "$1" = "-h" ] || [ "$1" = "--helper" ]; then
    show_help
    exit 0
fi

if [ "$1" = "--cancel" ]; then
	exec wpall --list "previous_wpdall"
	exit $?
fi

if [ "$1" = "--list" ] && [ -n "$2" ]; then
	extensions=$(cat "$2")
else
	extensions=$(php -d memory_limit=512M $(which wp) --allow-root plugin list --status=active --format=csv --field=name)
fi

if [ -z "$extensions" ]; then
    echo -e "${BLUE}[ INFO ]${NC} Pas d'extension à désactiver"
    exit 0
fi

if [ -e "previous_wpdall" ]; then
	rm  "previous_wpdall"
fi

good_display()
{
    while read -r line; do
        if [[ "$line" =~ Warning:\ (.*) ]]; then
            local detail="${BASH_REMATCH[1]}"
            echo -e "${YELLOW}[ ATTENTION ]${NC} $detail"
            continue
        fi

        if [[ "$line" =~ \'(.*)\' ]]; then
            local plugin="${BASH_REMATCH[1]}"
            echo -e "${GREEN}[ SUCCÈS ]${NC} désactivation de ${PURPLE}${plugin}${NC}"
            echo "$plugin" >> "previous_wpdall"
            continue
        fi

        if [[ "$line" =~ Error:\ (.*) ]]; then
            local detail="${BASH_REMATCH[1]}"
            echo -e "${RED}[ ERREUR ]${NC} $detail"
            continue
        fi
    done
}
php -d memory_limit=512M $(which wp) --allow-root plugin deactivate $extensions | good_display
# echo -e "${GREEN}[ SUCCÈS ]$NC fini !"
