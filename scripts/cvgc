#/bin/bash
source "/root/custom_cmds/includes/utils.sh"
source "/root/custom_cmds/includes/cv_source.sh"

### Aliases pour git clone de l'extension de CiviCRM et activation //experimental >> à simplifier
function cvgc() {
    instance=$(getplesksite) 
    testCMS

    while [ "$cms_instance" == "wordpress" ]; do 
        cd $racine/$instance/httpdocs/wp-content/uploads/civicrm/ext && git clone "$1" # git clone sur le repertoire ext
        extension=$(echo "$1" | awk -F'/' '{print $NF}' | sed 's/\.git$//') # récupère ce qu'il y'a avant le .git

        #cd "$extension" # cd vers le dossier de l'extension installée selon le nom déconstruit ! intérêt ?
        extracted_string=$(echo "$extension" | awk -F '.' '{print $NF}') && echo "Nom de l'extension clonée : $extracted_string"
        ##cv ext:enable "$extracted_string" && cv ext:upgrade-db && rep
        cv en "$extracted_string" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été installée"
        break
    done

    while [ "$cms_instance" == "drupal" ]; do 
        cd $racine/$instance/httpdocs/sites/default/files/civicrm/ext && git clone "$1" # git clone sur le repertoire ext
        extension=$(echo "$1" | awk -F'/' '{print $NF}' | sed 's/\.git$//') # récupère ce qu'il y'a avant le .git

        #cd "$extension" # cd vers le dossier de l'extension installée selon le nom déconstruit ! intérêt ?
        extracted_string=$(echo "$extension" | awk -F '.' '{print $NF}') && echo "Nom de l'extension clonée : $extracted_string"
        ##cv ext:enable "$extracted_string" && cv ext:upgrade-db && rep
        cv en "$extracted_string" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été installée"
        break
    done

    while [ "$cms_instance" == "standalone" ]; do 
        cd $racine/$instance/httpdocs/ext && git clone "$1" # git clone sur le repertoire ext
        extension=$(echo "$1" | awk -F'/' '{print $NF}' | sed 's/\.git$//') # récupère ce qu'il y'a avant le .git

        #cd "$extension" # cd vers le dossier de l'extension installée selon le nom déconstruit ! intérêt ?
        extracted_string=$(echo "$extension" | awk -F '.' '{print $NF}') && echo "Nom de l'extension clonée : $extracted_string"
        ##cv ext:enable "$extracted_string" && cv ext:upgrade-db && rep
        cv en "$extracted_string" && cv updb && rep
        echo -e "L'extension \033[32m$extension\033[0m a été installée"
        break
    done
    rep
}

cvgc $@
